---

---

<div class="container-medium">
    <div class="section-tittle center">
        <div class="badge two">
            <div class="tittle-badge">Контакты</div>
        </div>
        <div class="text-content">
            <h1 class="heading-style-h1 center">ОСТАВЬТЕ ЗАЯВКУ</h1>
            <p class="paragraph-large center">Обязательно укажите все поля</p>
        </div>
    </div>
    <div class="form-block w-form">
        <form
            id="email-form"
            name="email-form"
            data-name="Email Form"
            method="get"
            class="form"
            data-wf-page-id="68c0e3e4af3be748783bb0cd"
            data-wf-element-id="214819d7-9c84-8f6c-cee3-061e39d27264"
        >
            <div class="column-form">
                <div class="form-column">
                    <label for="name" class="sub-heading-regular"
                        >Как Вас зовут?</label
                    >
                    <input
                        class="text-field w-input"
                        maxlength="256"
                        name="name"
                        data-name="name"
                        placeholder="ФИО"
                        type="text"
                        id="name"
                        required
                    />
                </div>
                <div class="form-column">
                    <label for="phone" class="sub-heading-regular"
                        >Ваш номер телефона</label
                    >
                    <input
                        class="text-field w-input"
                        maxlength="256"
                        name="phone"
                        data-name="phone"
                        placeholder="+7 (___) ___-__-__"
                        type="tel"
                        id="phone"
                        required
                    />
                </div>
            </div>
            <div class="form-column">
                <label for="message" class="sub-heading-regular"
                    >Опишите ситуацию</label
                >
                <textarea
                    id="message"
                    name="message"
                    maxlength="5000"
                    data-name="message"
                    placeholder="Ваша проблема..."
                    class="text-field message _2 w-input"></textarea>
            </div>
            <div
                style="height: 100px; width: 100%;"
                id="captcha-container"
                class="smart-captcha"
                data-sitekey="ysc1_WmTJs7BjeMgfTCnfjNA87HagUsNtZJHXct1KAG1g325f683d"
            >
            </div>
            <div class="button-wrapper">
                <input
                    type="submit"
                    data-wait="Please wait..."
                    class="button w-button"
                    value="Отправить"
                />
            </div>
            <div class="tittle-badge">
                Пожалуйста, описывайте проблему максимально подробно — это
                поможет мастеру подготовить нужные запчасти и инструменты.<br />
            </div>
        </form>
        <div class="success-message w-form-done">
            <div class="paragraph-regular">Спасибо! Ваша заявка получена!</div>
        </div>
        <div class="error-message w-form-fail">
            <div class="paragraph-regular">
                Ой! При отправке формы произошла ошибка.
            </div>
        </div>
    </div>
</div>

<style>
    input[type="submit"]:disabled {
        background-color: #ccc;
        cursor: not-allowed;
    }
</style>

<script is:inline>
    const input = document.getElementById("phone");

    let isDeleting = false;

    async function sendFormData(data) {
        const res = await fetch(
            "https://functions.yandexcloud.net/d4e5el8aut2t39f15adr",
            {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            },
        );

        const json = await res.json();
        if (!res.ok) throw new Error(json.error || "Ошибка отправки");
        return json;
    }

    input.addEventListener("keydown", (e) => {
        isDeleting = e.key === "Backspace" || e.key === "Delete";
    });

    input.addEventListener("input", (e) => {
        if (isDeleting) return;

        let digits = e.target.value.replace(/\D/g, "");

        if (digits.startsWith("8")) digits = "7" + digits.slice(1);
        if (!digits.startsWith("7")) digits = "7" + digits;

        let v = "+7";

        if (digits.length > 1) v += " (" + digits.slice(1, 4);
        if (digits.length >= 4) v += ") " + digits.slice(4, 7);
        if (digits.length >= 7) v += "-" + digits.slice(7, 9);
        if (digits.length >= 9) v += "-" + digits.slice(9, 11);

        e.target.value = v;
    });

    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("email-form");
        const submitBtn = form.querySelector('input[type="submit"]');
        const requiredFields = form.querySelectorAll(
            "input[required], textarea[required]",
        );
        const successMessage = form.parentElement.querySelector(".w-form-done");
        const errorMessage = form.parentElement.querySelector(".w-form-fail");

        const CAPTCHA_VALIDATE_URL =
            "https://functions.yandexcloud.net/d4e939pp9u95f8katnq6";
        let captchaValid = false;
        let captchaToken = null;
        let captchaChecking = false;

        submitBtn.disabled = true;

        function areFieldsFilled() {
            return Array.from(requiredFields).every(
                (f) => f.value.trim() !== "",
            );
        }

        async function validateCaptcha(token) {
            if (captchaChecking) return;
            captchaChecking = true;

            try {
                const res = await fetch(CAPTCHA_VALIDATE_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ token }),
                });
                captchaValid = res.ok;
            } catch {
                captchaValid = false;
            } finally {
                captchaChecking = false;
                updateButtonState();
            }
        }

        function updateButtonState() {
            submitBtn.disabled = !(areFieldsFilled() && captchaValid);
        }

        requiredFields.forEach((field) => {
            field.addEventListener("input", updateButtonState);
        });

        setInterval(() => {
            if (!window.smartCaptcha) return;
            const token = window.smartCaptcha.getResponse();
            if (token && token !== captchaToken) {
                captchaToken = token;
                captchaValid = false;
                validateCaptcha(token);
            }
            if (!token) {
                captchaValid = false;
                captchaToken = null;
                updateButtonState();
            }
        }, 500);

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;

            const data = new FormData(form);
            const payload = {
                name: data.get("name"),
                phone: data.get("phone"),
                message: data.get("message"),
            };

            try {
                const result = await sendFormData(payload);

                if (result.success) {
                    // скрываем форму и показываем успешное сообщение
                    form.style.display = "none";
                    successMessage.style.display = "block";
                    errorMessage.style.display = "none";
                } else {
                    throw new Error("Ошибка отправки");
                }
            } catch (err) {
                console.error(err);
                // показываем сообщение об ошибке
                errorMessage.style.display = "block";
                successMessage.style.display = "none";
            } finally {
                submitBtn.disabled = false;
            }
        });
    });
</script>
